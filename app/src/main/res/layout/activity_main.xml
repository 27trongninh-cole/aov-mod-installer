<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_vertical"
    android:background="#1a1a2e">

    <!-- Icon -->
    <ImageView
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:src="@mipmap/ic_launcher"
        android:layout_gravity="center"
        android:layout_marginBottom="12dp" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AOV Mod Installer"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#e94560"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Liên Quân Mobile • by Ninfinity"
        android:textSize="13sp"
        android:textColor="#666666"
        android:gravity="center"
        android:layout_marginBottom="28dp" />

    <!-- Shizuku status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_background"
        android:padding="14dp"
        android:gravity="center"
        android:layout_marginBottom="28dp">

        <TextView
            android:id="@+id/tv_shizuku_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shizuku: Đang kiểm tra..."
            android:textColor="#888888"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Fix Resources -->
    <Button
        android:id="@+id/btn_fix_resources"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="🔧  Fix Resources"
        android:textSize="16sp"
        android:backgroundTint="#e94560"
        android:layout_marginBottom="12dp" />

    <!-- Install Mod -->
    <Button
        android:id="@+id/btn_install_mod"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="📦  Cài file Mod"
        android:textSize="16sp"
        android:backgroundTint="#0f3460"
        android:layout_marginBottom="12dp" />

    <!-- Remove Mod -->
    <Button
        android:id="@+id/btn_remove_mod"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="🗑️  Xóa tất cả Mod"
        android:textSize="16sp"
        android:backgroundTint="#333333"
        android:layout_marginBottom="20dp" />

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="#e94560"
        android:layout_marginBottom="20dp" />

    <!-- Credit -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ⓒ Ninfinity | Infinite Creativity. All rights reserved."
        android:textSize="11sp"
        android:textColor="#444444"
        android:gravity="center" />

</LinearLayout>
