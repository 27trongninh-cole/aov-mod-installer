<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#1a1a2e">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎮 Mod Installer"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#e94560"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cài mod vào Android/data/ qua Shizuku"
        android:textSize="13sp"
        android:textColor="#888888"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Status card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_background"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trạng thái: "
            android:textColor="#888888"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đang kiểm tra Shizuku..."
            android:textColor="#e94560"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Buttons -->
    <Button
        android:id="@+id/btn_pick_file"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📦  Chọn file ZIP mod"
        android:textSize="16sp"
        android:backgroundTint="#16213e"
        android:strokeColor="#e94560"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_install"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🚀  Cài mod"
        android:textSize="16sp"
        android:backgroundTint="#e94560"
        android:layout_marginBottom="16dp" />

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="#e94560"
        android:layout_marginBottom="16dp" />

    <!-- Log output -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Log:"
        android:textColor="#888888"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/card_background">

        <TextView
            android:id="@+id/tv_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text=""
            android:textColor="#00ff88"
            android:textSize="12sp"
            android:fontFamily="monospace" />
    </ScrollView>

</LinearLayout>
